# EditorConfig — applies to all DBIO distributions checked out under dbio-dev
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{pm,pl,t,pod}]
indent_style = space
indent_size = 2

[*.ini]
indent_style = space
indent_size = 2

[cpanfile]
indent_style = space
indent_size = 2

[Makefile*]
indent_style = tab

[*.md]
trim_trailing_whitespace = false

[*.json]
indent_style = space
indent_size = 2
